{
  "agentFramework": {
    "maxParallelAgents": 10,
    "timeout": 3600,
    "retryAttempts": 3,
    "logLevel": "info"
  },
  "autonomousAgents": {
    "dependencyManager": {
      "enabled": true,
      "autonomyLevel": "high",
      "description": "Manages dependency updates across repositories",
      "features": {
        "securittyUpdates": true,
        "batchMinorPatch": true,
        "autoMerge": true,
        "scheduleCheck": "hourly"
      },
      "config": {
        "autoMergeOnCIPassed": true,
        "requireApprovals": false,
        "batchStrategy": "same-ecosystem"
      }
    },
    "codeQualityManager": {
      "enabled": true,
      "autonomyLevel": "medium",
      "description": "Manages code formatting, linting, and quality checks",
      "features": {
        "autoFormat": true,
        "autoLint": true,
        "enforceStyles": true,
        "generateReports": true
      },
      "config": {
        "formatTools": ["prettier", "eslint", "black", "gofmt"],
        "autoCommit": true,
        "reportInterval": "daily"
      }
    },
    "documentationManager": {
      "enabled": true,
      "autonomyLevel": "medium",
      "description": "Maintains and updates documentation",
      "features": {
        "generateFromCode": true,
        "updateChangelogs": true,
        "maintainREADME": true,
        "generateAPIDocs": true
      },
      "config": {
        "docGenerators": ["typedoc", "sphinx", "godoc"],
        "autoCommit": true,
        "updateFrequency": "on-release"
      }
    },
    "securityManager": {
      "enabled": true,
      "autonomyLevel": "high",
      "description": "Monitors and responds to security alerts",
      "features": {
        "scanDependencies": true,
        "detectSecrets": true,
        "generateSecurityReports": true,
        "autoCreateAlerts": true
      },
      "config": {
        "scanTools": ["dependabot", "snyk", "gitguardian"],
        "alertThreshold": "medium",
        "autoNotify": true
      }
    },
    "releaseManager": {
      "enabled": true,
      "autonomyLevel": "medium",
      "description": "Automates release and versioning processes",
      "features": {
        "semanticVersioning": true,
        "generateReleaseNotes": true,
        "createGitTags": true,
        "autoPublish": false
      },
      "config": {
        "versioningStrategy": "semver",
        "changelogFormat": "keep-a-changelog",
        "releaseFrequency": "manual"
      }
    }
  },
  "autonomyLevels": {
    "manual": {
      "description": "All actions require manual approval",
      "autoExecution": false,
      "requireApprovals": true
    },
    "low": {
      "description": "Agent suggests actions but requires approval",
      "autoExecution": false,
      "requireApprovals": true
    },
    "medium": {
      "description": "Agent auto-executes low-risk actions, requires approval for high-risk",
      "autoExecution": true,
      "requireApprovals": false,
      "requireApprovalsFor": ["major-changes", "external-repositories"]
    },
    "high": {
      "description": "Agent auto-executes all safe actions without approval",
      "autoExecution": true,
      "requireApprovals": false
    }
  }
}
